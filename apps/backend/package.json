{
	"name": "@ca3/backend",
	"type": "module",
	"exports": {
		"./chat": "./src/types/chat.ts",
		"./usage": "./src/types/usage.ts",
		"./llm": "./src/types/llm.ts",
		"./memory": "./src/types/memory.ts",
		"./saved-prompts": "./src/types/saved-prompt.ts",
		"./tools": "./src/agents/tools/index.ts",
		"./providers": "./src/agents/providers.ts",
		"./log": "./src/types/log.ts",
		"./provider-meta": "./src/agents/provider-meta.ts"
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"fastapi": "cd ../../cli && uv run ../apps/backend/fastapi/main.py",
		"build": "tsup src/index.ts --format esm --target node20 --minify",
		"build:standalone": "bun build src/cli.ts --compile --outfile ca3-analytics-server --external playwright-core --external puppeteer-core --external @boxlite-ai/boxlite --external @pydantic/monty --compile-autoload-package-json",
		"start": "node dist/index.js",
		"test": "vitest run tests/ca3-sql-tool.test.ts tests/core-routes.test.ts tests/agent-manager.test.ts tests/test-routes.test.ts tests/project-config.test.ts tests/eval-verifier.test.ts",
		"lint": "tsc --noEmit && eslint",
		"lint:fix": "eslint --fix",
		"db:generate": "bash scripts/db.generate.sh",
		"db:migrate": "bun scripts/db.migrate.ts",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:studio": "drizzle-kit studio",
		"db:drop": "drizzle-kit drop",
		"db:reset": "rm db.sqlite",
		"db:seed": "bun scripts/db.seed.ts",
		"db:seed:cloud": "bun scripts/db.seed-cloud.ts",
		"db:check-migrations": "bun scripts/db.check-migrations.ts",
		"format": "prettier --write .",
		"test:tool-outputs": "PRINT_OUTPUT=true vitest run tests/tool-outputs/"
	},
	"dependencies": {
		"@ai-sdk/amazon-bedrock": "^4.0.69",
		"@ai-sdk/anthropic": "^3.0.76",
		"@ai-sdk/azure": "^3.0.49",
		"@ai-sdk/google": "^3.0.16",
		"@ai-sdk/google-vertex": "^4.0.80",
		"@ai-sdk/mistral": "^3.0.13",
		"@ai-sdk/openai": "^3.0.1",
		"@anthropic-ai/sdk": "^0.95.1",
		"@aws-sdk/credential-providers": "^3.1030.0",
		"@azure/identity": "^4.13.0",
		"@duckdb/node-api": "^1.4.4-r.1",
		"@fastify/formbody": "^8.0.2",
		"@fastify/multipart": "^10.0.0",
		"@fastify/static": "^8.1.0",
		"@openrouter/ai-sdk-provider": "^2.2.3",
		"@pydantic/monty": "^0.0.7",
		"@resvg/resvg-js": "^2.6.2",
		"@types/nodemailer": "^7.0.9",
		"@vscode/ripgrep": "^1.17.0",
		"ai": "^6.0.176",
		"ai-sdk-ollama": "^3.7.1",
		"axios": "^1.16.0",
		"better-auth": "^1.4.10",
		"better-sqlite3": "^12.5.0",
		"chat": "^4.15.0",
		"cheerio": "^1.2.0",
		"cron-parser": "^5.5.0",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.45.1",
		"drizzle-query-logger": "^1.1.2",
		"fastify": "^5.6.2",
		"fastify-plugin": "^5.1.0",
		"fastify-raw-body": "^5.0.0",
		"fastify-type-provider-zod": "^6.1.0",
		"gray-matter": "^4.0.3",
		"js-yaml": "^4.1.1",
		"node-sql-parser": "^5.4.0",
		"nodemailer": "^7.0.13",
		"pg": "^8.16.3",
		"postgres": "^3.4.8",
		"posthog-node": "^5.21.2",
		"prompt-mentions": "^0.0.32",
		"puppeteer-core": "^24.40.0",
		"sql-parser-cst": "^0.42.0",
		"uuid": "^14.0.0",
		"zod": "^4.4.3"
	},
	"optionalDependencies": {
		"@esbuild/linux-x64": "^0.27.4"
	},
	"devDependencies": {
		"@eslint/js": "^9.18.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/bun": "^1.3.5",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.0.3",
		"@types/pg": "^8.16.0",
		"@types/uuid": "^10.0.0",
		"drizzle-kit": "^0.31.8",
		"eslint": "^9.18.0",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"pino-pretty": "^13.1.3",
		"tsup": "^8.5.1",
		"typescript-eslint": "^8.21.0",
		"vitest": "^4.0.16"
	}
}
